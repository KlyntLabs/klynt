# Backend
RUST_LOG=debug
# Note: the backend config loader uses "__" as the nested-key separator.
KLYNT_API__HOST=127.0.0.1
KLYNT_API__PORT=3001
# `api.allowed_origins` is a list; use JSON array syntax to override it:
# KLYNT_API__ALLOWED_ORIGINS='["http://localhost:5174"]'
# KLYNT_RATE_LIMITER__ENABLED=true
# KLYNT_RATE_LIMITER__MAX_REQUESTS=5
# KLYNT_RATE_LIMITER__WINDOW_SECONDS=900

# Frontend
VITE_API_BASE_URL=http://localhost:3001/api/v1
VITE_APP_NAME=Klynt

# Infrastructure (used by Docker Compose; the backend does not connect yet)
POSTGRES_DB=klynt
POSTGRES_USER=klynt
POSTGRES_PASSWORD=klynt
POSTGRES_PORT=5432
# Backend config loader reads these with the KLYNT_ prefix.
KLYNT_DATABASE_URL=postgresql://klynt:klynt@postgres:5432/klynt
KLYNT_REDIS_URL=redis://redis:6379
# Non-prefixed variables are used by Docker Compose / sqlx CLI only.
DATABASE_URL=postgresql://klynt:klynt@postgres:5432/klynt
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# Docker Compose port overrides
KLYNT_BACKEND_PORT=3001
KLYNT_FRONTEND_PORT=5174
KLYNT_STORYBOOK_PORT=6006

# Docker notes
# --------------
# When running under Docker, KLYNT_API__HOST is overridden to 0.0.0.0 inside the
# container by docker-compose.dev.yml / docker-compose.yml so the API accepts
# traffic from outside the container. You do not need to change it here.
#
# Copy this file to .env before running locally or with Docker:
#   cp .env.example .env
