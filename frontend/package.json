{
  "name": "klynt-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:storybook": "STORYBOOK_TEST=true vitest run --project storybook",
    "typecheck": "tsc -b",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "analyze": "ANALYZE=true bun run build",
    "check:performance": "./scripts/check-performance-budget.sh",
    "prepare": "lefthook install",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@astryxdesign/core": "^0.1.4",
    "@astryxdesign/theme-neutral": "^0.1.4",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-query-devtools": "^5.74.0",
    "axe-core": "^4.12.1",
    "axios": "^1.8.0",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.41.0",
    "humps": "^2.0.1",
    "i18next": "^26.3.2",
    "i18next-browser-languagedetector": "^8.2.1",
    "isomorphic-dompurify": "^3.18.0",
    "lucide-react": "^1.21.0",
    "marked": "^18.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.56.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.6.0",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@astryxdesign/cli": "^0.1.4",
    "@biomejs/biome": "^2.5.1",
    "@chromatic-com/storybook": "^5.2.1",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/humps": "^2.0.6",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.9",
    "msw": "^2.7.0",
    "pg": "^8.22.0",
    "playwright": "^1.61.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "^10.4.6",
    "typescript": "~6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
