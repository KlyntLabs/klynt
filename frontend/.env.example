# Frontend environment variables
# Use a relative path so the Vite dev proxy can route /api to the backend while
# keeping all requests under .lvh.me (required for cross-subdomain session cookies).
VITE_API_BASE_URL=/api/v1
VITE_APP_NAME=Klynt
# Base domain used for subdomain routing (no scheme, no leading dot).
# Local dev uses lvh.me, which resolves *.lvh.me to 127.0.0.1.
VITE_APP_DOMAIN=lvh.me
VITE_APP_PROTOCOL=http
