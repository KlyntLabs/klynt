# Local development: allow the Vite dev server to send credentials.
# The wildcard origin supports the *.lvh.me subdomain dev setup.
KLYNT_API__ALLOWED_ORIGINS='["http://localhost:5174", "http://lvh.me:5174", "http://*.lvh.me:5174"]'
# Empty or '[]' disables CORS credentials and falls back to '*'
# KLYNT_API__ALLOWED_ORIGINS='[]'

# Cookie domain: leave empty for localhost (browser uses the current host and
# omits the Domain attribute), or use '.lvh.me' / '.klynt.dev' / '.klynt.edu'
# for cross-subdomain SSO.
KLYNT_COOKIE_DOMAIN=.lvh.me
KLYNT_COOKIE_SECURE=false
KLYNT_COOKIE_SAMESITE=Lax

# --- Email (Mailpit for local dev) ---
# Use "mock" for in-memory capture (default) or "smtp" to send through Mailpit.
KLYNT_EMAIL__PROVIDER=mock
KLYNT_EMAIL__SMTP__HOST=localhost
KLYNT_EMAIL__SMTP__PORT=1025
KLYNT_EMAIL__SMTP__FROM=noreply@klynt.local
# KLYNT_EMAIL__SMTP__USERNAME=
# KLYNT_EMAIL__SMTP__PASSWORD=
KLYNT_EMAIL__SMTP__TLS=false

# --- Production examples ---
# Domain attribute for session cookies. Leading dot enables cross-subdomain SSO.
# KLYNT_COOKIE_DOMAIN=.klynt.edu
# Whether session cookies require HTTPS.
# WARNING: Must be "true" in production where TLS is terminated. Leaving this
# "false" in production sends session cookies over plaintext HTTP and exposes
# users to session hijacking.
# KLYNT_COOKIE_SECURE=true
