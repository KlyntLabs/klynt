{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                r.id,\n                r.tenant_id,\n                r.name,\n                r.description AS \"description!\",\n                r.is_custom,\n                r.is_system,\n                r.created_at,\n                r.updated_at,\n                COALESCE(\n                    array_agg(rp.permission_id ORDER BY rp.permission_id)\n                    FILTER (WHERE rp.permission_id IS NOT NULL),\n                    '{}'\n                ) AS \"permission_ids!\"\n            FROM tenant_roles r\n            LEFT JOIN role_permissions rp ON rp.role_id = r.id\n            WHERE r.tenant_id = $1 AND r.id = $2\n            GROUP BY r.id\n            ",
