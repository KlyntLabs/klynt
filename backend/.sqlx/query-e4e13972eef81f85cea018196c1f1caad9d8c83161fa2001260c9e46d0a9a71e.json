{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                t.id, t.slug, t.name,\n                m.role, m.joined_at\n            FROM tenants t\n            JOIN user_tenant_memberships m ON m.tenant_id = t.id\n            WHERE m.user_id = $1\n            ORDER BY t.created_at DESC\n            ",
